          "name": "Rotate KEK",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"{{kekReason}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/admin/keys/kek/rotate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "admin",
                "keys",
                "kek",
                "rotate"
              ]
            },
            "description": "Triggers a KEK rotation and stores the rotationId for later retrieval."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Rotate KEK returns 202', function () { pm.response.to.have.status(202); });",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('kekRotationId', body.data.rotationId);",
